{
  "compilerOptions": {
    "strict": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "noEmit": true,
    "paths": {
      "react": ["./node_modules/preact/compat/src/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/preact/jsx-runtime/src/index.d.ts"],
      "react-dom": ["./node_modules/preact/compat/src/index.d.ts"],
      "react-dom/*": ["./node_modules/preact/compat/src/*"]
    }
  },
  "include": ["src", "server.ts", "env.d.ts"],
  "exclude": ["dist", "node_modules", "packages"]
}
