{
  "name": "web-ui-color-palette",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/ui-ui-color-palette"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --ssr src/entry-server.tsx --outDir dist/server",
    "start": "node --import tsx/esm server.ts",
    "preview": "NODE_ENV=production node --import tsx/esm server.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "preact": "^10.6.4",
    "preact-iso": "^2.9.1",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat",
    "ui-ui-color-palette": "*"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.1",
    "@types/express": "^5.0.3",
    "@types/node": "latest",
    "express": "^5.1.0",
    "tsx": "^4.20.3",
    "typescript": "latest",
    "vite": "^6.3.5"
  }
}
